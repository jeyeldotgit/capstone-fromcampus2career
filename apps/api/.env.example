NODE_ENV=development
API_PORT=3001
API_BASE_PATH=/api/v1
# Copy all Supabase values from the same project used by apps/data-pipeline/.env.
# Never commit real credentials.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Must point to the same database target as apps/data-pipeline/.env (host + database name).
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
REDIS_URL=https://example.upstash.io
