PYTHON_ENV=development
# Copy all Supabase values from the same project used by apps/api/.env.
# Never commit real credentials.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Must point to the same database target as apps/api/.env (host + database name).
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_STORAGE_BUCKET=market-datasets
PIPELINE_BATCH_SIZE=500
SDI_MIN_EVIDENCE_COUNT=5
DECAY_MIN_SNAPSHOTS=3
DECAY_THRESHOLD=-0.10
