# Shared root defaults
NODE_ENV=development

# API defaults
API_PORT=3001
API_BASE_PATH=/api/v1

# Admin defaults
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=From Campus to Career Admin

# Pipeline defaults
PYTHON_ENV=development
PIPELINE_BATCH_SIZE=500
SDI_MIN_EVIDENCE_COUNT=5
DECAY_MIN_SNAPSHOTS=3
DECAY_THRESHOLD=-0.10
